{
  "rewrites": [
    { "source": "/", "destination": "/pages/index.html" },
    { "source": "/(.*)", "destination": "/pages/$1" }
  ],
  "headers": [
    {
      "source": "/assets/(js|css)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}